<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 카드의 배경 색 -->
    <solid android:color="@android:color/white" />

    <!-- 모서리 둥글기 -->
    <corners android:radius="8dp" />

    <!-- 테두리 -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" /> <!-- 연한 회색 -->

    <!-- 그림자 효과 -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
