<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/color_picker_check_tv"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:background="@drawable/background_radius_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="확인"
        android:textSize="13sp"
        android:gravity="center"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        android:layout_marginBottom="85dp" />
    
    <FrameLayout
        android:layout_width="292dp"
        android:layout_height="80dp"
        android:background="@drawable/background_radius_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="161dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp">
                <ImageView
                    android:id="@+id/color_picker_purple_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_purple_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_purple_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp">
                <ImageView
                    android:id="@+id/color_picker_red_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_red_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_red_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp">
                <ImageView
                    android:id="@+id/color_picker_skyblue_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_skyblue_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_skyblue_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp">
                <ImageView
                    android:id="@+id/color_picker_gray_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_gray_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_gray_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>>

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp">
                <ImageView
                    android:id="@+id/color_picker_green_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_green_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_green_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp">
                <ImageView
                    android:id="@+id/color_picker_yellow_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_yellow_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_yellow_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp">
                <ImageView
                    android:id="@+id/color_picker_pink_iv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/btn_pink_circle"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/color_picker_pink_ring_iv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_black_ring"
                    android:layout_gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>