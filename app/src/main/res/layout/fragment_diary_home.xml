<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.home.diary.DiaryHomeFragment">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/diary_complete_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="자동 일기 제작"
                android:fontFamily="@font/pretendard_regular"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_refresh"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toEndOf="@id/diary_complete_tv"
                app:layout_constraintTop_toTopOf="@id/diary_complete_tv"
                app:layout_constraintBottom_toBottomOf="@id/diary_complete_tv"/>

            <ImageView
                android:id="@+id/diary_complete_close_iv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_close"
                android:layout_marginEnd="16dp"
                app:layout_constraintTop_toTopOf="@id/diary_complete_tv"
                app:layout_constraintBottom_toBottomOf="@id/diary_complete_tv"
                app:layout_constraintEnd_toEndOf="parent"/>

<!--            "오늘"에 해당하는 날짜 띄우기-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_regular"
                android:layout_marginTop="40dp"
                android:textSize="16sp"
                android:text="12월 5일 목요일"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/ic_question_box"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/diary_complete_tv"/>


            <ImageView
                android:id="@+id/diary_character_iv"
                android:layout_width="116dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_angry"
                android:layout_marginTop="173dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/diary_complete_tv"/>


            <!-- 내용이 있을 때 보여지는 컴포넌트-->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/diary_text_cl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="80dp"
                app:layout_constraintTop_toBottomOf="@id/diary_character_iv"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <TextView
                    android:id="@+id/diary_text_tv"
                    android:layout_width="292dp"
                    android:layout_height="164dp"
                    android:fontFamily="@font/pretendard_regular"
                    android:visibility="visible"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:scrollbars="vertical"
                    android:paddingTop="15dp"
                    android:paddingBottom="49dp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/ic_diary_box"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_gallery"
                    android:layout_marginEnd="15dp"
                    android:layout_marginBottom="15dp"
                    app:layout_constraintBottom_toBottomOf="@id/diary_text_tv"
                    app:layout_constraintEnd_toEndOf="@id/diary_text_tv"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>


<!--            텍스트가 비어있을 때 보여지는 컴포넌트-->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/diary_blank_text_cl"
                android:layout_width="wrap_content"
                android:layout_marginTop="88dp"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/diary_character_iv">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_blank_diary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_pen"
                    android:layout_marginEnd="15dp"
                    android:layout_marginBottom="15dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>


            </androidx.constraintlayout.widget.ConstraintLayout>





            <!-- 이미지 추가전 visibility == gone으로 해두었음-->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/diary_home_Addimg_cl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@id/diary_text_cl"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <TextView
                    android:id="@+id/diary_imgAdd_tv"
                    android:layout_width="292dp"
                    android:layout_height="52dp"
                    android:text="사진 최대 4장 첨부해주세요."
                    android:fontFamily="@font/pretendard_regular"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/ic_question_box"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_gallery"
                    android:layout_marginVertical="14dp"
                    android:layout_marginEnd="14dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!--이미지 4장 추가된 컴포넌트 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/diary_img_cl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="100dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/diary_text_cl"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:id="@+id/diary_img_iv"
                    android:layout_width="292dp"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_fitimage"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ImageView
                    android:id="@+id/diarmy_gallery_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_gallery"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageView
                    android:id="@+id/diary_img1_iv"
                    android:layout_width="124dp"
                    android:layout_height="85dp"
                    android:elevation="4dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="49dp"
                    android:background="@color/medium_gray"
                    app:layout_constraintTop_toTopOf="@id/diary_img_iv"
                    app:layout_constraintStart_toStartOf="@id/diary_img_iv"/>
                <ImageView
                    android:id="@+id/diary_img2_iv"
                    android:layout_width="124dp"
                    android:layout_height="85dp"
                    android:elevation="4dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="49dp"
                    android:background="@color/medium_gray"
                    app:layout_constraintTop_toTopOf="@id/diary_img_iv"
                    app:layout_constraintEnd_toEndOf="@id/diary_img_iv"/>

                <ImageView
                    android:id="@+id/diary_img3_iv"
                    android:layout_width="124dp"
                    android:layout_height="85dp"
                    android:elevation="4dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/medium_gray"
                    app:layout_constraintTop_toBottomOf="@id/diary_img1_iv"
                    app:layout_constraintStart_toStartOf="@id/diary_img_iv"/>

                <ImageView
                    android:id="@+id/diary_img4_iv"
                    android:layout_width="124dp"
                    android:layout_height="85dp"
                    android:elevation="4dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/medium_gray"
                    app:layout_constraintTop_toBottomOf="@id/diary_img2_iv"
                    app:layout_constraintEnd_toEndOf="@id/diary_img_iv"/>




            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

</ScrollView>
