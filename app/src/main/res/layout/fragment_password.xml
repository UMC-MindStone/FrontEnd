<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageButton
        android:id="@+id/ib_back_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@android:color/transparent"/>

    <TextView
        android:id="@+id/tv_title1_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="비밀번호 설정"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tv_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="편집"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="26dp"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tv_question1_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="기존 비밀번호를 입력하세요."
        android:textStyle="bold"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_title1_password"
        android:layout_marginStart="40dp"
        android:layout_marginTop="75dp"/>

    <EditText
        android:id="@+id/et_password1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@+id/tv_question1_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/border_shape"
        android:padding="15dp"
        android:hint="비밀번호 *"
        android:textSize="18sp"
        android:textColorHint="#AFAFAF"/>

    <TextView
        android:id="@+id/tv_password1_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#DC3D31"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/et_password1"
        app:layout_constraintStart_toStartOf="@id/et_password1" />

    <TextView
        android:id="@+id/tv_question2_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="새로운 비밀번호를 입력하세요."
        android:textStyle="bold"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_password1"
        android:layout_marginStart="40dp"
        android:layout_marginTop="130dp"/>

    <EditText
        android:id="@+id/et_password2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@+id/tv_question2_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/border_shape"
        android:padding="15dp"
        android:hint="비밀번호 *"
        android:textSize="18sp"
        android:textColorHint="#AFAFAF"/>

    <TextView
        android:id="@+id/tv_password2_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#DC3D31"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/et_password2"
        app:layout_constraintStart_toStartOf="@id/et_password2" />

    <EditText
        android:id="@+id/et_password3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@+id/et_password2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/border_shape"
        android:padding="15dp"
        android:hint="비밀번호 확인 *"
        android:textSize="18sp"
        android:textColorHint="#AFAFAF"/>

    <TextView
        android:id="@+id/tv_password3_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#DC3D31"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/et_password3"
        app:layout_constraintStart_toStartOf="@id/et_password3" />

</androidx.constraintlayout.widget.ConstraintLayout>