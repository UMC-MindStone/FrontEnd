<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AfterLoginActivity"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그아웃"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="43dp"
        android:layout_marginEnd="19dp"/>
    
    <ImageView
        android:layout_width="260dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_hello"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="133dp"/>
    
    <ImageView
        android:layout_width="112dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_calm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="476dp"/>
    
    <ImageView
        android:id="@+id/after_login_next_iv"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:src="@drawable/btn_pink_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="43dp"/>
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:text="다음"
        app:layout_constraintTop_toTopOf="@id/after_login_next_iv"
        app:layout_constraintBottom_toBottomOf="@id/after_login_next_iv"
        app:layout_constraintStart_toStartOf="@id/after_login_next_iv"
        app:layout_constraintEnd_toEndOf="@id/after_login_next_iv"/>

</androidx.constraintlayout.widget.ConstraintLayout>