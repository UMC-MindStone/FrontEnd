<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginHorizontal="32dp"
    android:background="@drawable/border_shape_dialog">

    <TextView
        android:id="@+id/tv_secession_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="계정 탈퇴 하시겠습니까?"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:layout_gravity="center" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_secession"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="탈퇴"
            android:textColor="#6C6C6C"
            android:textSize="13sp"
            android:backgroundTint="@android:color/white"
            app:strokeColor="#AFAFAF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16px"
            android:layout_marginHorizontal="6dp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="48dp"
            android:layout_marginEnd="32dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_secession_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="취소"
            android:textColor="#6C6C6C"
            android:textSize="13sp"
            android:backgroundTint="@android:color/white"
            app:strokeColor="#AFAFAF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16px"
            android:layout_marginHorizontal="6dp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="48dp"/>
    </LinearLayout>
</LinearLayout>
