<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_200"
    tools:context=".ui.home.emotion.EmotionReasonFragment2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/reason_question_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_question_box"
            android:text="이유는 무엇인가요?"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_regular"
            android:gravity="center"
            android:layout_marginTop="90dp"
            android:layout_marginStart="34dp"
            android:layout_marginEnd="34dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/notification"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/btn_notification"
            android:layout_margin="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:id="@+id/notification_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_notification_number"
            android:text="2"
            android:textSize="6sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="2dp"
            app:layout_constraintRight_toRightOf="@id/notification"
            app:layout_constraintBottom_toBottomOf="@id/notification"/>

        <TextView
            android:id="@+id/reason_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이유 작성 칸"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/pretendard_regular"
            android:textColor="@color/black"
            android:gravity="center"
            android:maxWidth="235dp"
            android:maxLines="10"
            android:background="@drawable/ic_bubble_center"
            android:layout_marginBottom="15dp"
            app:layout_constraintBottom_toTopOf="@id/icon_iv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/icon_iv"
            android:src="@drawable/ic_calm_charac"
            android:layout_width="112dp"
            android:layout_height="96dp"
            android:layout_marginTop="470dp"
            android:layout_marginStart="124dp"
            android:layout_marginEnd="124dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.example.mindstone.EmotionStatusBar
            android:id="@+id/status_bar"
            android:background="@drawable/ic_status_bar"
            android:layout_width="300dp"
            android:layout_height="25dp"
            android:layout_marginTop="55dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            app:layout_constraintTop_toBottomOf="@+id/icon_iv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>