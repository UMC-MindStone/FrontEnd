<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".auth.LoginActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/login_logo_iv"
        android:layout_width="208dp"
        android:layout_height="44dp"
        android:layout_marginTop="160dp"
        android:src="@drawable/ic_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <!-- 이메일 입력 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/loginEmailTil"
        android:hint="이메일"
        style="@style/Login_TextInputLayoutStyle"
        android:textColorHint="@color/black"
        app:boxStrokeColor="#AFAFAF"
        app:helperText=""
        app:helperTextTextColor="@color/error"
        app:errorEnabled="true"
        app:errorIconDrawable="@drawable/ic_emailerror"
        app:layout_constraintTop_toBottomOf="@id/login_logo_iv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="94dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/login_email_et"
            android:layout_width="292dp"
            android:layout_height="52dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:inputType="textEmailAddress"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 이메일 오류 메시지 -->
    <TextView
        android:id="@+id/loginEmailErrorTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pretendard_regular"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/loginEmailTil"
        app:layout_constraintTop_toBottomOf="@id/loginEmailTil"/>


    <!-- 비밀번호 입력 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/loginPasswordTil"
        style="@style/Login_TextInputLayoutStyle"
        android:hint="비밀번호"
        android:textColorHint="@color/black"
        app:boxStrokeColor="#AFAFAF"
        app:helperText=""
        app:helperTextTextColor="@color/error"
        app:errorEnabled="true"
        app:errorIconDrawable="@drawable/ic_emailerror"
        app:layout_constraintTop_toBottomOf="@+id/loginEmailTil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/login_password_et"
            android:layout_width="292dp"
            android:layout_height="52dp"
            android:inputType="textPassword"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 비밀번호 오류 메시지 -->
    <TextView
        android:id="@+id/loginPasswordErrorTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pretendard_regular"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/loginPasswordTil"
        app:layout_constraintTop_toBottomOf="@id/loginPasswordTil"/>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="@+id/login_login_iv"
        app:layout_constraintBottom_toTopOf="@+id/login_login_iv">

        <ImageView
            android:id="@+id/login_checked_iv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/btn_checked_normal"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/login_checked2_iv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/btn_checked_selected"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/login_autoLogin_tv"
            android:text="자동 로그인"
            android:textSize="13dp"
            android:fontFamily="@font/pretendard_regular"
            android:layout_width="66dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:layout_marginBottom="10dp"
            android:layout_marginLeft="8dp"
            app:layout_constraintLeft_toRightOf="@id/login_checked_iv"/>

    </LinearLayout>

    <ImageView
        android:id="@+id/login_login_iv"
        android:src="@drawable/btn_login"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:layout_marginTop="68dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/loginPasswordTil" />


    <!-- Fragment가 표시될 컨테이너 추가 -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>


    <TextView
        android:id="@+id/login_findEmail_tv"
        android:text="이메일 찾기"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="74dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="3dp"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintLeft_toLeftOf="@id/login_login_iv"/>

    <TextView
        android:id="@+id/login_findPW_tv"
        android:text="비밀번호 재설정"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="85dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="18dp"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintLeft_toLeftOf="@id/login_bar1_iv" />

    <TextView
        android:id="@+id/login_join_tv"
        android:text="회원가입"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="74dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintRight_toRightOf="@id/login_login_iv" />


    <ImageView
        android:id="@+id/login_bar1_iv"
        android:src="@drawable/ic_bar"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginTop="21dp"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toBottomOf="@id/login_login_iv"
        app:layout_constraintLeft_toRightOf="@id/login_findEmail_tv" />

    <ImageView
        android:id="@+id/login_bar2_iv"
        android:src="@drawable/ic_bar"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginTop="21dp"
        android:layout_marginLeft="19dp"
        app:layout_constraintTop_toBottomOf="@id/login_login_iv"
        app:layout_constraintLeft_toRightOf="@id/login_findPW_tv" />

</androidx.constraintlayout.widget.ConstraintLayout>