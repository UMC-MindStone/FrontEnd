<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_200"
    tools:context=".home.EmotionReasonFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <TextView
            android:id="@+id/reason_question_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_question_box"
            android:text="이유는 무엇인가요?"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_regular"
            android:gravity="center"
            android:layout_marginTop="90dp"
            android:layout_marginStart="34dp"
            android:layout_marginEnd="34dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/reason_bubble_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_bubble_happy"
            app:tint="@color/happyColor"
            android:layout_marginTop="194dp"
            app:layout_constraintTop_toBottomOf="@id/reason_question_tv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:padding="8dp"/>

        <EditText
            android:id="@+id/reason_et"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="입력"
            android:minWidth="80dp"
            android:maxWidth="200dp"
            android:minHeight="40dp"
            android:maxLines="3"
            android:background="@null"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:imeOptions="actionDone"
            app:layout_constraintTop_toTopOf="@id/reason_bubble_iv"
            app:layout_constraintBottom_toBottomOf="@id/reason_bubble_iv"
            app:layout_constraintStart_toStartOf="@id/reason_bubble_iv"
            app:layout_constraintEnd_toEndOf="@id/reason_bubble_iv"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>