<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:layout_marginTop="16dp">

        <ImageButton
            android:id="@+id/ib_back_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:srcCompat="@drawable/ic_back"
            android:layout_marginStart="16dp"
            android:layout_gravity="center"
            android:contentDescription="@string/search_button_description"/>

        <TextView
            android:id="@+id/tv_title1_search1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="기본 인적사항"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="-40dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. 생년월일을 선택해주세요."
        android:textSize="20sp"
        android:layout_marginTop="75dp"
        android:layout_marginStart="40dp"
        android:textStyle="bold"/>

    <!-- 생년월일 입력 부분 -->
    <LinearLayout
        android:id="@+id/parent_layout_search1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <EditText
                android:id="@+id/et_year_search1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="YYYY"
                android:inputType="number"
                android:gravity="center"
                android:layout_margin="2dp"
                android:padding="16dp"
                android:background="@drawable/border_shape"/>

            <Spinner
                android:id="@+id/spinner_month"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:entries="@array/months"
                android:layout_margin="2dp"
                android:padding="16dp"
                android:background="@drawable/border_shape"/>

            <Spinner
                android:id="@+id/spinner_day"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:entries="@array/days"
                android:layout_margin="2dp"
                android:padding="16dp"
                android:background="@drawable/border_shape"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 직업 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:layout_marginHorizontal="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. 직업을 선택해주세요."
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinner_job"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/jobs"
            android:padding="16dp"
            android:background="@drawable/border_shape"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- MBTI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:layout_marginHorizontal="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. MBTI를 선택해주세요."
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinner_mbti"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/mbti"
            android:background="@drawable/border_shape"
            android:padding="16dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- 다음 버튼 -->
    <ImageButton
        android:id="@+id/ib_search_next"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="155dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/search_button_description"
        app:srcCompat="@drawable/btn_search_next" />
</LinearLayout>
