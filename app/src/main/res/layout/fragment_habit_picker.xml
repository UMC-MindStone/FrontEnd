<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:context=".HabitPickerFragment"
    android:background="@android:color/transparent">

    <TextView
        android:id="@+id/habit_picker_check_tv"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:background="@drawable/background_radius_gray"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="다음"
        android:textSize="13sp"
        android:gravity="center"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"/>

    <FrameLayout
        android:id="@+id/habit_picker_container_fl"
        android:layout_width="292dp"
        android:layout_height="120dp"
        android:background="@drawable/background_radius_gray"
        app:layout_constraintBottom_toTopOf="@id/habit_picker_check_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">
        <NumberPicker
            android:id="@+id/habit_picker_habit_np"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="20dp"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>