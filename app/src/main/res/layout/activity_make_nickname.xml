<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.search.MakeNicknameActivity"
    android:background="@color/white">

    <ImageView
        android:id="@+id/make_nickname_back_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="16dp"/>
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="닉네임 설정"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="38dp"/>

    <TextView
        android:id="@+id/make_nickname_name_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="닉네임을 입력해주세요."
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="119dp"
        android:layout_marginStart="34dp"/>

    <TextView
        android:id="@+id/make_nickname_korean_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="한글/영문/숫자 8자이내(특수문자 불가능)"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/make_nickname_name_tv"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="34dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/make_nickname_name_til"
        style="@style/TextInputLayoutStyle"
        android:hint="닉네임"
        android:layout_marginTop="173dp"
        android:textColorHint="@color/black"
        app:boxStrokeColor="@color/black"
        app:helperText=""
        app:helperTextTextColor="@color/error"
        app:errorEnabled="true"
        app:errorIconDrawable="@drawable/ic_emailerror"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/nicknameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이미 존재하는 닉네임입니다."
        android:textSize="10sp"
        android:textColor="@color/red"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/make_nickname_name_til"
        android:layout_marginStart="34dp"
        android:visibility="gone"/>

    <ImageView
        android:layout_width="112dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_calm_charac"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="476dp"/>

    <ImageView
        android:id="@+id/after_login_next_iv"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:src="@drawable/btn_pink_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="43dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:text="다음"
        app:layout_constraintTop_toTopOf="@id/after_login_next_iv"
        app:layout_constraintBottom_toBottomOf="@id/after_login_next_iv"
        app:layout_constraintStart_toStartOf="@id/after_login_next_iv"
        app:layout_constraintEnd_toEndOf="@id/after_login_next_iv"/>

</androidx.constraintlayout.widget.ConstraintLayout>