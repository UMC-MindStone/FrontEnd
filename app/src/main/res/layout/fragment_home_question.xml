<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.home.HomeQuestionFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/home_status_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_question_box"
            android:text="지금 어떤 상태인가요?"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_regular"
            android:gravity="center"
            android:layout_marginTop="90dp"
            android:layout_marginStart="34dp"
            android:layout_marginEnd="34dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/home_another_question_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="다른 질문 보기"
            android:textSize="13sp"
            android:textColor="@color/medium_gray"
            app:layout_constraintTop_toBottomOf="@id/home_status_tv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/btn_notification"
            android:layout_margin="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/home_question_editText_iv"
            android:layout_width="292dp"
            android:layout_height="196dp"
            android:layout_marginTop="89dp"
            android:src="@drawable/ic_edittext"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/home_status_tv" />

        <EditText
            android:id="@+id/overlayEditText"
            android:layout_width="@id/home_question_editText_iv"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:hint="내용 입력"
            android:maxHeight="180dp"
            android:scrollbars="vertical"
            android:inputType="textMultiLine"
            android:padding="8dp"
            android:fontFamily="@font/pretendard_regular"
            android:textColor="@color/black"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="@id/home_question_editText_iv"
            app:layout_constraintStart_toStartOf="@id/home_question_editText_iv"
            app:layout_constraintTop_toTopOf="@id/home_question_editText_iv" />

        <TextView
            android:id="@+id/home_complete_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            android:text="확인"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/home_question_editText_iv"
            app:layout_constraintEnd_toEndOf="@id/home_question_editText_iv"
            app:layout_constraintStart_toStartOf="@id/home_question_editText_iv"/>

        <ImageView
            android:id="@+id/home_questionmark_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_questionmark"
            android:layout_marginTop="195dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/home_status_tv"/>

        <ImageView
            android:layout_width="116dp"
            android:layout_height="98dp"
            android:src="@drawable/ic_happy"
            android:layout_marginTop="469dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>



        <ImageView
            android:id="@+id/home_status_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_status_bar"
            android:layout_marginTop="615dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/home_to_homefragment_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="넘어가기"
            android:layout_marginTop="12dp"
            android:textColor="@color/medium_gray"
            app:layout_constraintTop_toBottomOf="@id/home_status_iv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>