<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:backgroundTint="#FFFFFF">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/item_notification_cl"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/item_notiIcon_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_emotion"
            android:backgroundTint="@color/point_red"
            android:layout_marginVertical="19dp"
            android:layout_marginStart="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
        <TextView
            android:id="@+id/item_notiText_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="21dp"
            android:text="습관 기록 안한지 1일이 지났어요"
            android:textSize="16sp"
            android:maxWidth="230dp"
            app:layout_constraintStart_toEndOf="@id/item_notiIcon_iv"
            app:layout_constraintTop_toTopOf="@id/item_notiIcon_iv"
            app:layout_constraintBottom_toBottomOf="@id/item_notiIcon_iv"/>
        <TextView
            android:id="@+id/item_notiDate_tv"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:textColor="@color/medium_gray"
            android:text="1일전"
            android:textSize="13sp"
            android:layout_marginEnd="15dp"
            android:layout_marginVertical="21.5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>