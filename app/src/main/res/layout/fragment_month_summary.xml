<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.emotion.MonthSummaryFragment"
    android:background="@color/white">

    <TextView
        android:id="@+id/month_summary_month_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1월 감정 요약"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="90dp"/>

    <TextView
        android:id="@+id/month_summary_compare_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1월 초에 비해 1월 말에 감정 관리가 잘 되었습니다."
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="7dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="스트레스는 과제, 인간관계로 인해 발생했고 운동, 모임, 독서 순으로 관리를 했습니다."
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="53dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>