<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".HomeQuestionFragment1">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/home_question_editText_iv"
            android:layout_width="292dp"
            android:layout_height="196dp"
            android:layout_marginTop="223dp"
            android:src="@drawable/ic_edittext"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/overlayEditText"
            android:layout_width="@id/home_question_editText_iv"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:hint="내용 입력"
            android:maxHeight="180dp"
            android:scrollbars="vertical"
            android:inputType="textMultiLine"
            android:padding="8dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="@id/home_question_editText_iv"
            app:layout_constraintStart_toStartOf="@id/home_question_editText_iv"
            app:layout_constraintTop_toTopOf="@id/home_question_editText_iv" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            android:text="확인"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/home_question_editText_iv"
            app:layout_constraintEnd_toEndOf="@id/home_question_editText_iv"
            app:layout_constraintStart_toStartOf="@id/home_question_editText_iv"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>