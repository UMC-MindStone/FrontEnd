<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/dialog_background">

    <!-- 다이얼로그 메시지 -->
    <TextView
        android:id="@+id/tv_message"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:text="다이얼로그 메시지"
        android:textSize="16sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/button_container"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp" />

    <!-- 버튼 그룹 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/button_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_message"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="17dp">

        <!-- 첫 번째 버튼 -->
        <TextView
            android:id="@+id/btn_action1"
            android:layout_width="92dp"
            android:layout_height="38dp"
            android:background="@drawable/background_radius_gray"
            android:text="기본 버튼 1"
            android:fontFamily="@font/pretendard_regular"
            android:textSize="13sp"
            android:textColor="#6C6C6C"
            android:padding="5dp"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_action2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="8dp" />

        <!-- 두 번째 버튼 -->
        <TextView
            android:id="@+id/btn_action2"
            android:layout_width="143dp"
            android:layout_height="38dp"
            android:background="@drawable/background_radius_gray"
            android:fontFamily="@font/pretendard_regular"
            android:gravity="center"
            android:padding="5dp"
            android:text="기본 버튼 2"
            android:textColor="#6C6C6C"
            android:textSize="13sp"
            android:layout_marginStart="25dp"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/btn_action1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>