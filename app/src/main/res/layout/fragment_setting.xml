<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageButton
        android:id="@+id/ib_back_setting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@android:color/transparent"/>

    <TextView
        android:id="@+id/tv_title_setting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="기본 알림 설정"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- 전체 알림 -->
    <LinearLayout
        android:id="@+id/ll_alarm1_setting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingStart="40dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/ib_back_setting">

        <TextView
            android:id="@+id/tv_alarm1_setting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="전체 알림"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"/>

        <Switch
            android:id="@+id/sw_alarm1_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_line_divider1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/line_divider"
        app:layout_constraintTop_toBottomOf="@+id/ll_alarm1_setting"/>

    <!-- 기록 알림 -->
    <ImageView
        android:id="@+id/iv_bg_setting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_alarm1_setting"
        app:srcCompat="@drawable/bg_pink_setting" />

    <LinearLayout
        android:id="@+id/ll_alarm2_setting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingStart="40dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/iv_bg_setting">

        <TextView
            android:id="@+id/tv_alarm2_setting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="기록 알림"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"/>

        <Switch
            android:id="@+id/sw_alarm2_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- 알림 시간 -->
    <LinearLayout
        android:id="@+id/ll_time_setting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingStart="40dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/ll_alarm2_setting">

        <TextView
            android:id="@+id/tv_time_setting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="알림 시간"
            android:textSize="14sp"
            android:textColor="@android:color/black" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_alarm_times"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_line_divider2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/line_divider"
        app:layout_constraintTop_toBottomOf="@+id/ll_time_setting"/>

    <!-- 하루 마무리 알림 -->
    <LinearLayout
        android:id="@+id/ll_alarm3_setting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingStart="40dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/ll_time_setting">

        <TextView
            android:id="@+id/tv_alarm3_setting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="하루 마무리 알림"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"/>

        <Switch
            android:id="@+id/sw_alarm3_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- 전체 알림 텍스트 -->
    <LinearLayout
        android:id="@+id/ll_time2_setting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingStart="40dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/ll_alarm3_setting">

        <TextView
            android:id="@+id/tv_time2_setting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="전체 알림"
            android:textSize="14sp"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tv_time2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="23:50"
            android:textSize="13sp"
            android:textColor="#B0B0B0" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_line_divider3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/line_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_time2_setting"/>
</androidx.constraintlayout.widget.ConstraintLayout>