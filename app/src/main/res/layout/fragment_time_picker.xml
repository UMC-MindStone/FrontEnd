<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TimePickerFragment">

    <TextView
        android:id="@+id/time_picker_next_tv"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:background="@drawable/background_radius_gray"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="다음"
        android:textSize="13sp"
        android:gravity="center"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        android:layout_marginBottom="85dp" />

    <TextView
        android:id="@+id/time_picker_check_tv"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:background="@drawable/background_radius_gray"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="확인"
        android:textSize="13sp"
        android:gravity="center"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        android:layout_marginBottom="85dp"
        android:visibility="gone"/>

    <FrameLayout
        android:id="@+id/time_picker_container_fl"
        android:layout_width="292dp"
        android:layout_height="120dp"
        android:background="@drawable/background_radius_gray"
        app:layout_constraintBottom_toTopOf="@id/time_picker_next_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <NumberPicker
                android:id="@+id/time_picker_noon_np"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <NumberPicker
                android:id="@+id/time_picker_hour_np"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <NumberPicker
                android:id="@+id/time_picker_minute_np"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
        </LinearLayout>



    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>