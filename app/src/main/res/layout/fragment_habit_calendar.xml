<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".HabitCalendarFragment">

    <TextView
        android:id="@+id/habit_calendar_date_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2024 12월"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="38dp"
        android:layout_marginStart="19dp"/>
    
    <ImageView
        android:id="@+id/habit_calendar_down_iv"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/btn_down_normal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/habit_calendar_date_tv"
        android:layout_marginTop="41dp"
        android:layout_marginStart="7dp"/>
    
    <ImageView
        android:id="@+id/habit_calendar_graph_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_graph_normal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"/>

    <TextView
        android:id="@+id/habit_calendar_stat_tv"
        android:layout_width="292dp"
        android:layout_height="wrap_content"
        android:text="12월에는 44% 기록했고\n습관 행동 100%를 9번 달성했어요."
        android:textSize="16sp"
        android:fontFamily="@font/pretendard_regular"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="123dp"/>

    <GridView
        android:id="@+id/habit_calendar_calendar_gv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/habit_calendar_stat_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/habit_calendar_right_iv"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="54dp"
        android:layout_marginBottom="110dp"
        android:numColumns="7"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp"
        android:padding="8dp"
        android:gravity="center"
        android:stretchMode="columnWidth" />

    
    <ImageView
        android:id="@+id/habit_calendar_right_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_right_arrow_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="15dp"
        android:layout_marginEnd="24dp"/>
    
    <ImageView
        android:id="@+id/habit_calendar_left_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_left_arrow_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="15dp"
        android:layout_marginStart="24dp"/>

    <FrameLayout
        android:id="@+id/habit_calendar_container_fl"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />



</androidx.constraintlayout.widget.ConstraintLayout>