<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.emotion.EmotionCalendarFragment"
    android:background="@color/background">

    <!-- 상단 날짜 텍스트 -->
    <TextView
        android:id="@+id/emotion_calendar_date_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2024 12월"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="38dp"
        android:layout_marginStart="19dp"/>

    <!-- 하단 화살표 아이콘 -->
    <ImageView
        android:id="@+id/emotion_calendar_down_iv"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/btn_down_normal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/emotion_calendar_date_tv"
        android:layout_marginTop="41dp"
        android:layout_marginStart="7dp"/>

    <GridView
        android:id="@+id/emotion_calendar_calendar_gv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/emotion_calendar_date_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/emotion_calendar_viewpager2_cv"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="35dp"
        android:layout_marginBottom="15dp"
        android:numColumns="7"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp"
        android:padding="8dp"
        android:gravity="center"
        android:stretchMode="columnWidth" />


    <!-- ViewPager2 통계 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/emotion_calendar_viewpager2_cv"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="88dp">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/emotion_calendar_stat_vp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </androidx.cardview.widget.CardView>


    <!-- CircleIndicator3 -->
    <me.relex.circleindicator.CircleIndicator3
        android:id="@+id/emotion_calendar_stat_ci"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="61dp"
        app:ci_drawable="@drawable/ic_black_selected"
        app:ci_drawable_unselected="@drawable/ic_gray_unselected"/>

    <!-- 오른쪽 화살표 아이콘 -->
    <ImageView
        android:id="@+id/emotion_calendar_right_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_right_arrow_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="15dp"
        android:layout_marginEnd="24dp"/>

    <!-- 왼쪽 화살표 아이콘 -->
    <ImageView
        android:id="@+id/emotion_calendar_left_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_left_arrow_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="15dp"
        android:layout_marginStart="24dp"/>

    <FrameLayout
        android:id="@+id/emotion_calendar_container_fl"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
