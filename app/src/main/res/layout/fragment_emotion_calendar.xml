<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EmotionCalendarFragment">
    
    <TextView
        android:id="@+id/emotion_calendar_date_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2024 12월"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="38dp"
        android:layout_marginStart="19dp"/>
    
    <ImageView
        android:id="@+id/emotion_calendar_down_iv"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/btn_down_normal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/emotion_calendar_date_tv"
        android:layout_marginTop="41dp"
        android:layout_marginStart="7dp"/>

    <com.prolificinteractive.materialcalendarview.MaterialCalendarView
        android:id="@+id/emotion_calendar_calendar_mcv"
        android:layout_width="312dp"
        android:layout_height="358dp"
        app:layout_constraintTop_toBottomOf="@id/emotion_calendar_date_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="46dp"/>

    <androidx.viewpager2.widget.ViewPager2
        android:layout_width="320dp"
        android:layout_height="140dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="88dp"/>

    <me.relex.circleindicator.CircleIndicator3
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="61dp"/>

    <ImageView
        android:id="@+id/emotion_calendar_right_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_right_arrow_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="15dp"
        android:layout_marginEnd="24dp"/>

    <ImageView
        android:id="@+id/emotion_calendar_left_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_left_arrow_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="15dp"
        android:layout_marginStart="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>