<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    tools:context=".DiaryEditFragment">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/diary_loading_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="38dp"
            android:text="자동 일기 제작"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <ImageView
            android:id="@+id/diary_edit_close_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_close"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/diary_loading_tv"
            app:layout_constraintBottom_toBottomOf="@id/diary_loading_tv"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/diary_editText_tv"
            android:layout_width="292dp"
            android:layout_height="352dp"
            android:layout_marginTop="40dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="77dp"
            android:textSize="14sp"
            android:text=""
            android:background="@drawable/background_textfield"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/diary_loading_tv"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/btn_completed"
            android:layout_marginBottom="15dp"
            app:layout_constraintEnd_toEndOf="@id/diary_editText_tv"
            app:layout_constraintStart_toStartOf="@id/diary_editText_tv"
            app:layout_constraintBottom_toBottomOf="@id/diary_editText_tv"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>