<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tv_title1_mypage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="마이페이지"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"/>

    <ImageView
        android:id="@+id/iv_bg_mypage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/bg_mypage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title1_mypage"
        android:layout_marginTop="40dp"/>

    <ImageView
        android:id="@+id/iv_ic_calm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_calm_mypage"
        app:layout_constraintTop_toTopOf="@+id/iv_bg_mypage"
        app:layout_constraintStart_toStartOf="@+id/iv_bg_mypage"
        android:layout_marginTop="34dp"
        android:layout_marginStart="34dp"/>

    <TextView
        android:id="@+id/tv_nickname_mypage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="밍돌"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/iv_ic_calm"
        app:layout_constraintTop_toTopOf="@+id/iv_bg_mypage"
        android:layout_marginTop="48dp"
        android:layout_marginStart="34dp"/>

    <TextView
        android:id="@+id/tv_email_mypage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="xxxx@gmail.com"
        app:layout_constraintStart_toEndOf="@+id/iv_ic_calm"
        app:layout_constraintTop_toBottomOf="@+id/tv_nickname_mypage"
        android:layout_marginStart="34dp"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_mypage_options"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/iv_bg_mypage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_option_mypage" />

</androidx.constraintlayout.widget.ConstraintLayout>