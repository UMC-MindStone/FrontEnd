<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <!-- MBTI Grid -->
    <TableLayout
        android:id="@+id/tl_mbti_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*"
        android:paddingVertical="8dp"
        android:background="@drawable/border_shape_dialog">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="5dp">

            <TextView
                android:id="@+id/tv_mbti_e"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="E"
                android:textSize="18sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_mbti_n"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="N"
                android:textSize="18sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_mbti_f"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="F"
                android:textSize="18sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_mbti_p"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="P"
                android:textSize="18sp"
                android:padding="8dp" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="5dp">

            <TextView
                android:id="@+id/tv_mbti_i"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="I"
                android:textSize="18sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_mbti_s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="S"
                android:textSize="18sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_mbti_t"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="T"
                android:textSize="18sp"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_mbti_j"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="J"
                android:textSize="18sp"
                android:padding="8dp" />
        </TableRow>
    </TableLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_fix_mbti"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="확인"
        android:textColor="#6C6C6C"
        android:textSize="13sp"
        android:backgroundTint="@android:color/white"
        app:strokeColor="#494949"
        app:strokeWidth="1.5dp"
        app:cornerRadius="16px"
        android:layout_marginTop="27dp"
        android:padding="16dp"/>
</LinearLayout>
