<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.home.DiaryImgFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/diary_img_auto_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="38dp"
            android:fontFamily="@font/pretendard"
            android:text="자동 일기 제작"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/diary_img_date_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="38dp"
            android:fontFamily="@font/pretendard"
            android:text="자동 일기 제작"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/diary_img_close_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/diary_img_box_iv"
            android:layout_width="292dp"
            android:layout_height="352dp"
            android:layout_marginTop="106dp"
            android:background="@drawable/ic_diary_edit_box"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:src="@drawable/btn_completed"
            android:elevation ="8dp"
            app:layout_constraintBottom_toBottomOf="@id/diary_img_box_iv"
            app:layout_constraintEnd_toEndOf="@id/diary_img_box_iv"
            app:layout_constraintStart_toStartOf="@id/diary_img_box_iv" />

        <ImageView
            android:id="@+id/diary_add_img_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_gallery"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="@id/diary_img_box_iv"
            app:layout_constraintTop_toTopOf="@id/diary_img_box_iv"/>
        <TextView
            android:id="@+id/diary_add_img_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="4dp"
            android:fontFamily="@font/pretendard_regular"
            android:textSize="16sp"
            android:text="사진 최대 4장 첨부해주세요."
            app:layout_constraintStart_toStartOf="@id/diary_img_box_iv"
            app:layout_constraintEnd_toEndOf="@id/diary_img_box_iv"
            app:layout_constraintTop_toTopOf="@id/diary_img_box_iv"/>


        <!--임의 이미지 추가 뷰 : 나중에 background white로 바꿔줘야 합니다.-->
        <ImageView
            android:id="@+id/diary_img1_iv"
            android:layout_width="124dp"
            android:layout_height="85dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:elevation="4dp"
            android:scaleType="centerCrop"
            android:background="@color/medium_gray"
            app:layout_constraintTop_toBottomOf="@+id/diary_add_img_tv"
            app:layout_constraintStart_toStartOf="@id/diary_img_box_iv"/>

        <ImageView
            android:id="@+id/diary_img2_iv"
            android:layout_width="124dp"
            android:layout_height="85dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            android:scaleType="centerCrop"
            android:background="@color/medium_gray"
            app:layout_constraintTop_toBottomOf="@id/diary_add_img_tv"
            app:layout_constraintEnd_toEndOf="@id/diary_img_box_iv"/>

        <ImageView
            android:id="@+id/diary_img3_iv"
            android:layout_width="124dp"
            android:layout_height="85dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:elevation="4dp"
            android:scaleType="centerCrop"
            android:background="@color/medium_gray"
            app:layout_constraintTop_toBottomOf="@+id/diary_img1_iv"
            app:layout_constraintStart_toStartOf="@id/diary_img_box_iv"/>

        <ImageView
            android:id="@+id/diary_img4_iv"
            android:layout_width="124dp"
            android:layout_height="85dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            android:scaleType="centerCrop"
            android:background="@color/medium_gray"
            app:layout_constraintTop_toBottomOf="@id/diary_img2_iv"
            app:layout_constraintEnd_toEndOf="@id/diary_img_box_iv"/>




    </androidx.constraintlayout.widget.ConstraintLayout>



</FrameLayout>