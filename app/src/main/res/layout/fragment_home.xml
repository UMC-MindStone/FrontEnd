<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary_200"
    tools:context=".ui.home.HomeFragment">

    <TextView
        android:id="@+id/home_status_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_question_box"
        android:text="지금 어떤 상태인가요?"
        android:textSize="16sp"
        android:fontFamily="@font/pretendard_regular"
        android:gravity="center"
        android:layout_marginTop="90dp"
        android:layout_marginStart="34dp"
        android:layout_marginEnd="34dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/notification"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/btn_notification"
        android:layout_margin="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/notification_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_notification_number"
        android:text="2"
        android:textSize="6sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="2dp"
        app:layout_constraintRight_toRightOf="@id/notification"
        app:layout_constraintBottom_toBottomOf="@id/notification"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/home_emotion_cl"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/home_status_tv">

        <ImageView
            android:id="@+id/home_angry_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_angry"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/home_depressed_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_depressed"
            android:layout_marginTop="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/home_angry_iv"/>

        <ImageView
            android:id="@+id/home_sad_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_sad"
            android:layout_marginTop="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/home_depressed_iv"/>

        <ImageView
            android:id="@+id/home_calm_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_calm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/home_sad_iv"
            app:layout_constraintRight_toLeftOf="@+id/home_joy_iv"/>

        <ImageView
            android:id="@+id/home_happy_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_happy"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/home_excited_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_excited"
            android:layout_marginTop="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/home_happy_iv"/>

        <ImageView
            android:id="@+id/home_joy_iv"
            android:layout_width="72dp"
            android:layout_height="46dp"
            android:src="@drawable/btn_joy"
            android:layout_marginTop="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/home_excited_iv"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/home_icon_iv"
        android:src="@drawable/ic_calm_charac"
        android:layout_width="112dp"
        android:layout_height="96dp"
        android:layout_marginTop="470dp"
        android:layout_marginStart="124dp"
        android:layout_marginEnd="124dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

        <com.example.mindstone.EmotionStatusBar
            android:id="@+id/status_bar"
            android:background="@drawable/ic_status_bar"
            android:layout_width="300dp"
            android:layout_height="25dp"
            android:layout_marginTop="55dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            app:layout_constraintTop_toBottomOf="@+id/home_icon_iv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>

