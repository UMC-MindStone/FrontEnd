<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.auth.signup.SignupPasswordActivity">

    <ImageView
        android:layout_width="12dp"
        android:layout_height="22dp"
        android:src="@drawable/btn_back"
        android:layout_marginStart="23dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textSize="20sp"
        android:fontFamily="@font/pretendard_regular"
        android:text="회원가입"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="34dp"
        android:layout_marginTop="95dp"
        android:fontFamily="@font/pretendard_regular"
        android:text="비밀번호를 확인해주세요"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/signup_password_til"
        android:layout_marginTop="136dp"
        android:hint="비밀번호*"
        android:fontFamily="@font/pretendard_regular"
        android:textColorHint="@color/black"
        app:helperText=""
        app:helperTextTextColor="@color/error"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:passwordToggleEnabled="true"
        style="@style/TextInputLayoutStyle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/signup_passwordText_tie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16.5dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/signup_passwordCheck_til"
        android:layout_marginTop="25dp"
        android:textColorHint="@color/black"
        android:hint="비밀번호 확인*"
        android:fontFamily="@font/pretendard_regular"
        app:helperText=""
        app:helperTextTextColor="@color/error"
        app:layout_constraintTop_toBottomOf="@id/signup_password_til"
        app:layout_constraintStart_toStartOf="parent"
        app:passwordToggleEnabled="true"
        style="@style/TextInputLayoutStyle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/signup_passwordCheckText_tie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16.5dp" />
    </com.google.android.material.textfield.TextInputLayout>


    <TextView
        android:id="@+id/signup_passwordNext_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_pink_background"
        android:text="다음"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:textAlignment="center"
        android:paddingVertical="15dp"
        android:layout_marginBottom="27dp"
        android:layout_marginHorizontal="34dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>