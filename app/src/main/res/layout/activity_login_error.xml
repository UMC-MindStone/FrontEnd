<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".auth.LoginErrorActivity">

    <ImageView
        android:id="@+id/login_back_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:src="@drawable/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard_regular"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/login_logo_iv"
        android:layout_width="208dp"
        android:layout_height="44dp"
        android:layout_marginTop="160dp"
        android:src="@drawable/ic_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/login_email_et"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:text="이메일"
        android:background="@drawable/background_radius_red"
        android:padding="16dp"
        android:fontFamily="@font/pretendard_regular"
        android:textSize="16sp"
        android:textColor="#494949"
        android:layout_marginTop="301dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <EditText
        android:id="@+id/login_password_et"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:text="비밀번호"
        android:background="@drawable/background_radius_red"
        android:padding="16dp"
        android:fontFamily="@font/pretendard_regular"
        android:textSize="16sp"
        android:textColor="#494949"
        android:layout_marginTop="374dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/login_caution1_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_caution_login_error"
        android:layout_marginTop="14dp"
        android:layout_marginRight="15dp"
        app:layout_constraintRight_toRightOf="@+id/login_email_et"
        app:layout_constraintTop_toTopOf="@id/login_email_et"/>

    <ImageView
        android:id="@+id/login_caution2_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_caution_login_error"
        android:layout_marginTop="14dp"
        android:layout_marginRight="15dp"
        app:layout_constraintRight_toRightOf="@+id/login_password_et"
        app:layout_constraintTop_toTopOf="@id/login_password_et"/>

    <TextView
        android:id="@+id/login_tv"
        android:text="example@example.com"
        android:textSize="10dp"
        android:textColor="#DC3D31"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="107dp"
        android:layout_height="14dp"
        android:gravity="center"
        android:layout_marginLeft="12dp"
        app:layout_constraintTop_toBottomOf="@+id/login_email_et"
        app:layout_constraintLeft_toLeftOf="@id/login_email_et"/>

    <TextView
        android:id="@+id/logintv"
        android:text="영문, 숫자, 특수문자 포함 8자이상"
        android:textSize="10dp"
        android:textColor="#DC3D31"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="134dp"
        android:layout_height="14dp"
        android:gravity="center"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toBottomOf="@+id/login_password_et"
        app:layout_constraintLeft_toLeftOf="@id/login_password_et"/>

    <ImageView
        android:id="@+id/login_check_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_check"
        android:layout_marginBottom="8dp"
        app:layout_constraintLeft_toLeftOf="@+id/login_login_iv"
        app:layout_constraintBottom_toTopOf="@+id/login_login_iv" />

    <TextView
        android:id="@+id/login_autoLogin_tv"
        android:text="자동 로그인"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="66dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:layout_marginLeft="8dp"
        app:layout_constraintBottom_toTopOf="@+id/login_login_iv"
        app:layout_constraintLeft_toRightOf="@id/login_check_iv"/>

    <ImageView
        android:id="@+id/login_login_iv"
        android:src="@drawable/btn_login"
        android:layout_width="292dp"
        android:layout_height="52dp"
        android:layout_marginTop="489dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/login_findEmail_tv"
        android:text="이메일 찾기"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="74dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="3dp"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintLeft_toLeftOf="@id/login_login_iv"/>

    <TextView
        android:id="@+id/login_resetPassword_tv"
        android:text="비밀번호 재설정"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="85dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="18dp"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintLeft_toLeftOf="@id/login_bar1_iv" />

    <TextView
        android:id="@+id/login_join_tv"
        android:text="회원가입"
        android:textSize="13dp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_width="74dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/login_login_iv"
        app:layout_constraintRight_toRightOf="@id/login_login_iv" />


    <ImageView
        android:id="@+id/login_bar1_iv"
        android:src="@drawable/ic_bar"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginTop="21dp"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toBottomOf="@id/login_login_iv"
        app:layout_constraintLeft_toRightOf="@id/login_findEmail_tv" />

    <ImageView
        android:id="@+id/login_bar2_iv"
        android:src="@drawable/ic_bar"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginTop="21dp"
        android:layout_marginLeft="19dp"
        app:layout_constraintTop_toBottomOf="@id/login_login_iv"
        app:layout_constraintLeft_toRightOf="@id/login_resetPassword_tv" />

</androidx.constraintlayout.widget.ConstraintLayout>