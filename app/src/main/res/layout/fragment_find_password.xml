<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    tools:context=".auth.FindPasswordFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/findPW_find_tv">

            <LinearLayout
                android:id="@+id/findEmailTab_ll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:text="이메일 찾기"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:fontFamily="@font/pretendard_regular"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/findPWTab_ll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/findPW_tv"
                    android:text="비밀번호 재설정"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:textColor="#B86774"
                    android:fontFamily="@font/pretendard_regular"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="75dp"
            app:layout_constraintTop_toBottomOf="@id/findPW_find_tv">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#BDBDBD"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_weight="1"
                android:background="#D998A4"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/back_iv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginLeft="16dp"
            android:src="@drawable/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/findPW_find_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이메일 찾기 / 비밀번호 재설정"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/pretendard_regular"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="175dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/pretendard_regular"
            android:text="회원가입 시 등록한 이메일을 입력해주세요."
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/findPW_email_et"
            app:layout_constraintLeft_toLeftOf="@id/findPW_email_et"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/findPW_iv"
            android:src="@drawable/btn_reset_password"
            android:layout_width="292dp"
            android:layout_height="52dp"
            android:layout_marginTop="325dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/findPW_email_et"
            android:layout_width="292dp"
            android:layout_height="52dp"
            android:layout_marginTop="229dp"
            android:background="@drawable/background_radius_gray"
            android:fontFamily="@font/pretendard_regular"
            android:padding="16dp"
            android:hint="이메일"
            android:textColor="#494949"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>